PORT=3000
MONGO_URI=mongodb://localhost:27017/techstore
CLIENT_URL=http://localhost:5173

# Auth - להחליף ל-secrets אקראיים באורך 32+ תווים בכל סביבה
JWT_SECRET=change-me-to-a-random-string-32-chars-min
JWT_EXPIRES_IN=24h
COOKIE_SECRET=change-me-to-another-random-string-32-chars-min
NODE_ENV=development

# AI feature (description generation + vision recognition)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_VISION_MODEL=gpt-5-mini
AI_VISION_CONFIDENCE_THRESHOLD=0.95
AI_VISION_MAX_RETRIES=2
AI_CACHE_TTL_MS=600000
